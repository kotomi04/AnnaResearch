{
  "schema": 2,
  "permissions": [
    "tools.invoke"
  ],
  "required_executas": [
    {
      "tool_id": "tool-test-llm-sampling-12345678",
      "min_version": "0.1.0",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "system_prompt_addendum": "The user has the LLM / Agent Test app open. It can call app-side anna.llm.complete, app-side anna.agent.session, and a backend Executa that exercises sampling/createMessage and agent/session.*.",
  "user_message_prefix_template": "[LLM / Agent Test] {user_message}",
  "tags": ["developer", "llm", "sampling", "agent", "test"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "LLM / Agent Test",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 420, "h": 360 },
        "default_size": { "w": 720, "h": 560 },
        "max_size": { "w": 960, "h": 760 },
        "resizable": true,
        "movable": true,
        "single_instance": true
      }
    ],
    "host_api": {
      "tools": ["required:tool-test-llm-sampling-12345678"],
      "chat": [],
      "artifact": [],
      "llm": ["complete"],
      "agent": {
        "session": { "auto": true, "fixed": null },
        "tools": ["tool-test-llm-sampling-12345678"]
      },
      "fs": [],
      "storage": [],
      "prefs": [],
      "window": []
    },
    "csp_overrides": {
      "style-src": ["'self'"],
      "script-src": ["'self'"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": [],
    "seed_storage": {},
    "user_id": 1
  }
}
